# Google AI API Key — from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=

# Secret key clients must send in the X-API-Key header
SERVICE_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
# Override when Gemini 3 Flash becomes available
GEMINI_MODEL=gemini-2.0-flash

# GCP project ID for Firestore — uses Application Default Credentials if omitted
# Required when running outside Cloud Run (local dev, Railway, etc.)
GCP_PROJECT_ID=

# Port — Railway injects this automatically, only needed for local dev
PORT=8000
